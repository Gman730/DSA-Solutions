13. Maximum Flow (Ford-Fulkerson with BFS / Edmonds-Karp)

pythonfrom collections import defaultdict, deque

def maxFlow(graph, source, sink):
    # graph: dict of dicts, graph[u][v] = capacity
    flow_graph = defaultdict(lambda: defaultdict(int))
    for u in graph:
        for v in graph[u]:
            flow_graph[u][v] = graph[u][v]

    def bfs():
        parent = {source: None}
        visited = {source}
        queue = deque([source])
        while queue:
            u = queue.popleft()
            if u == sink:
                break
            for v in flow_graph[u]:
                if v not in visited and flow_graph[u][v] > 0:
                    visited.add(v)
                    parent[v] = u
                    queue.append(v)
        return parent if sink in parent else None

    total_flow = 0
    while True:
        parent = bfs()
        if not parent:
            break
        path_flow = float('inf')
        v = sink
        while v != source:
            u = parent[v]
            path_flow = min(path_flow, flow_graph[u][v])
            v = u
        v = sink
        while v != source:
            u = parent[v]
            flow_graph[u][v] -= path_flow
            flow_graph[v][u] += path_flow
            v = u
        total_flow += path_flow
    return total_flow

Complexity: O(V*E^2) with Edmonds-Karp (BFS-based).
